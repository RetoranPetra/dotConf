{
	"extractor": {
		"base-directory": "~/gallery-dl/",
		"archive": "~/gallery-dl/archive.sqlite3",
		"postprocessors": [
			"giftomp4",
			"removeduplicateimages",
			"removeduplicatevideos"
		],
		"directory": [
			"{category}",
			"{author}"
		],
		"mtime": "{date}",
		"reddit": {
			"filename": "{date} {id}{num:? //>02} {title[:220]}.{extension}",
			"user": {
				"parent-directory": true,
				"parent-metadata": "_reddit"
			}
		},
		"reddit>*": {
			"mtime": "{_reddit[date]}",
			"filename": "{_reddit[date]} {_reddit[id]} {_reddit[title]}.{extension}",
			"directory": ["tmp"],
			"postprocessors": ["movetoparent"]
		}
	},
	"postprocessor": {
		"giftomp4" : {
				"name": "exec",
				"async" : false,
				"command" : "~/.config/gallery-dl/giftomp4.bash {}",
				"event" : "after",
				"filter": "extension == 'gif'"
		},
		"removeduplicateimages": {
			"name": "exec",
			"async": false,
			"command": "czkawka_cli image -d {_directory} -D AEO; if [ $? -eq 1 ]; then return 1; fi",
			"event": "finalize"
		},
		"removeduplicatevideos": {
			"name": "exec",
			"async": false,
			"command": "czkawka_cli video -d {_directory} -D AEO; if [ $? -eq 1 ]; then return 1; fi",
			"event": "finalize"
		},
		"movetoparent": {
			"name": "exec",
			"async": false,
			"command": "cd {_directory} && mv * .. && rmdir {_directory}"
		}
	}
}
