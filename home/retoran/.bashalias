#!/bin/bash

# Bash alias is declared in default arch profile, but should make it explicit.
alias ls='ls --color=tty'
alias l='ls -lah'
# End of arch implicit profile stuff.
#alias feh='feh -.'

fz() {
	"$@" "$(fzf)"
}
fzd() {
	"$@" "$(dirname "$(fzf)")"
}
fzcd() {
	fd cd "$@"
}
open() {
	if [ $# -eq 0 ]; then
		VAL=$(fzf)
		if [[ -n $VAL ]]; then
			handlr open "$VAL"
		fi
	fi
	for f in "$@"; do
		# TODO: Should check if default handlr is nvim for multiple and open them all at once.
		handlr open "$f"
	done
}
tmux-detatch() {
	tmux new-session -d -s "$1"
	tmux send-keys "${@:2}" C-m
}

# Specific java versions
java21() {
	export PATH="/lib/jvm/java-21-openjdk/bin:$PATH"
}
java17() {
	export PATH="/lib/jvm/java-17-openjdk/bin:$PATH"
}
java11() {
	export PATH="/lib/jvm/java-11-openjdk/bin:$PATH"
}
java8() {
	export PATH="/lib/jvm/java-8-openjdk/bin:$PATH"
}

# Machine specific things
update() {
	paru
	rustup update
	pipx upgrade-all
	# Don't want waydroid to upgrade automatically as it might mess up the arm emulation layer.
	#sudo waydroid upgrade
}
